# Intended for use with algutils.env (dotenv tests / dev)
# ALGODEV variable is pre-defined by algutils.env

# Variables below are OVERRIDEN if defined in environmrnt.
# To change this behaviour explicitely set ALG_DOTENV_OVER=0

# Below are fallback values. Preferably define them in your environment
ALG_LOCAL_DATA="~/data"
ALG_NET_DATA=/mnt/algo/DataSets

# by default ALG_DATA goes for ALG_LOCAL_DATA. Set directly in environment
ALG_DATA="${ALG_LOCAL_DATA}"

# Predefined group-wide conventions
ALG_RESOURCES="${ALGODEV}/resources"
ALG_ISSUES="${ALG_RESOURCES}/issues"

ALG_DATASETS="${ALG_DATA}/depth"

# Trained Locator(LOCAL_DATA/train, NET_DATA/train, envar=ALG_TRAINED, EIA)
ALG_TRAINED  # set to search this envar before other folders

# ALG_EVAL_CACHE="${ALG_DATA}/algo_cache"   # not in use YET
ALG_EVALS="${ALG_DATA}/evals"
ALG_BENCH="${ALG_DATA}/bench"             # obsolete?
