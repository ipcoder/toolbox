"""Configurable filesystem roots used across toolbox packages."""

from __future__ import annotations

import os
from pathlib import Path

from algutils.filesproc import Locator


def _root() -> Path:
    raw = os.environ.get("TOOLBOX_ROOT")
    if raw:
        return Path(raw).expanduser().resolve()
    return Path.cwd().resolve()


_root_path = _root()


class EnvLoc:
    """Locator bundle for standard toolbox directory layout (resolved at import time)."""

    DATA = Locator(_root_path / "data", envar="TOOLBOX_DATA")
    DATASETS = Locator(_root_path / "datasets", envar="TOOLBOX_DATASETS")
    RESOURCES = Locator(_root_path / "resources", envar="TOOLBOX_RESOURCES")
    ENGINES = Locator(_root_path / "engines", envar="TOOLBOX_ENGINES")
    ISSUES = Locator(_root_path / "issues", envar="TOOLBOX_ISSUES")
    EVALS = Locator(_root_path / "evals", envar="TOOLBOX_EVALS")
    ALG_CACHE = Locator(_root_path / ".alg_cache", envar="TOOLBOX_ALG_CACHE")

    _configured: str | None = None

    @classmethod
    def last_set(cls) -> bool:
        return cls._configured is not None or os.environ.get("TOOLBOX_ROOT") is not None

    @classmethod
    def reset(cls, env: str | Path | bool | None = None) -> type[EnvLoc]:
        """Record environment configuration; setting ``TOOLBOX_ROOT`` affects new processes."""
        if env is False:
            cls._configured = None
            os.environ.pop("TOOLBOX_ROOT", None)
            return cls
        if env is None or env is True:
            cls._configured = str(_root())
            return cls
        path = Path(env).expanduser().resolve()
        cls._configured = str(path)
        os.environ["TOOLBOX_ROOT"] = cls._configured
        return cls

    @classmethod
    def repr(cls, verbose: bool = False) -> str:
        return f"EnvLoc(TOOLBOX_ROOT={os.environ.get('TOOLBOX_ROOT', _root_path)!s}, verbose={verbose})"
